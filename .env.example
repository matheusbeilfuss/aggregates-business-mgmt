# Copy this file to .env and fill in the values

# Security
# Generate with: openssl rand -base64 32
JWT_SECRET=REPLACE_ME_WITH_OUTPUT_OF_openssl_rand_-base64_32
JWT_EXPIRATION=12h
COOKIE_SECURE=true

# Initial admin account
ADMIN_INITIAL_USERNAME=admin
ADMIN_INITIAL_PASSWORD=CHANGE_ME_strong_password_here

# PostgreSQL (dev/prod profiles only)
DATABASE_USER=abm
DATABASE_PASSWORD=CHANGE_ME_strong_password_here

# CORS
# In production with Nginx proxy, same origin is used, but Spring still
# needs an explicit value. Set to your domain, e.g.:
# CORS_ALLOWED_ORIGINS=https://app.yourdomain.com.br
CORS_ALLOWED_ORIGINS=http://localhost
